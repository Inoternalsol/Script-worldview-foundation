{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types"],
    "skipLibCheck": true,
    "paths": {
      "drizzle-orm": ["../node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../node_modules/drizzle-orm/*"]
    }
  },
  "include": ["src/**/*.ts"]
}

